#!/bin/bash
#
# Install the scripts in this repo as `git` subcommands and (optionally) set
# this repo's hook templates as the global git template dir.
#
# Defaults:
#   INSTALL_DIR=$HOME/.local/bin
#   SKIP_TEMPLATES=0
#
# Examples:
#   ./install                                  # default: symlink into ~/.local/bin (no sudo)
#   INSTALL_DIR=/usr/local/bin ./install       # system-wide install (sudo if needed)
#   SKIP_TEMPLATES=1 ./install                 # don't touch global init.templatedir

set -e

DIR="$(cd "$(dirname "$0")" && pwd)"
INSTALL_DIR="${INSTALL_DIR:-$HOME/.local/bin}"

mkdir -p "$INSTALL_DIR" 2>/dev/null || true

if [ -w "$INSTALL_DIR" ]; then
    SUDO=""
else
    SUDO="sudo"
fi

echo "Installing scripts -> $INSTALL_DIR"
$SUDO ln -vsf "$DIR"/scripts/* "$INSTALL_DIR/"

if [ "${SKIP_TEMPLATES:-0}" != "1" ]; then
    echo "Setting global init.templatedir -> $DIR/.git_templates"
    git config --global init.templatedir "$DIR/.git_templates"
fi

case ":$PATH:" in
    *":$INSTALL_DIR:"*) ;;
    *)
        echo
        echo "warning: $INSTALL_DIR is not on \$PATH"
        echo "add this to your shell rc (~/.zshrc or ~/.bashrc):"
        echo "  export PATH=\"$INSTALL_DIR:\$PATH\""
        ;;
esac

echo "Done."
